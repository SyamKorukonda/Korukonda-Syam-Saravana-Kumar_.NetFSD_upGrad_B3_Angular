@model IEnumerable<ContactInfo>

<h2>Contact List</h2>
<br />
<hr />


<p>
    <a asp-action="Create" class="btn btn-primary">Add Contact</a>
</p>
<hr />
<table border="1" cellpadding="10" cellspacing="0" class="table">
    <thead>
        <tr>
            <th>S.No</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Company</th>
            <th>Email</th>
            <th>Mobile</th>
            <th>Designation</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @{
            int count = 1;
        }

        @if (Model != null && Model.Any())
        {
            foreach (var contact in Model)
            {
                <tr>
                    <td>@count</td>
                    <td>@contact.FirstName</td>
                    <td>@contact.LastName</td>
                    <td>@contact.CompanyName</td>
                    <td>@contact.EmailId</td>
                    <td>@contact.MobileNo</td>
                    <td>@contact.Designation</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@contact.ContactId">Details</a> |
                        <a asp-action="Edit" asp-route-id="@contact.ContactId">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@contact.ContactId">Delete</a>
                    </td>
                </tr>

                count++;
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-danger text-center">No contacts found</td>
            </tr>
        }
    </tbody>
</table>
