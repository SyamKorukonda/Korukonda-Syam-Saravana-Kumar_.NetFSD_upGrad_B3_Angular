@model ContactInfo

<h2>Edit Contact</h2>
<hr />

<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <input type="hidden" asp-for="ContactId" />

    <div class="form-group">
        <label>First Name</label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Company</label>
        <select asp-for="CompanyId"
                asp-items="@(new SelectList(ViewBag.Companies, "CompanyId", "CompanyName"))"
                class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Department</label>
        <select asp-for="DepartmentId"
                asp-items="@(new SelectList(ViewBag.Departments, "DepartmentId", "DepartmentName"))"
                class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Email</label>
        <input asp-for="EmailId" class="form-control" />
    </div>

    <div class="form-group">
        <label>Mobile</label>
        <input asp-for="MobileNo" type="number" class="form-control" />

    </div>

    <div class="form-group">
        <label>Designation</label>
        <input asp-for="Designation" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

</form>