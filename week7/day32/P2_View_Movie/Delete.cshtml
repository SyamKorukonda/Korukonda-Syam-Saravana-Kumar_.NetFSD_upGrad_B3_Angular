@model Movie

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h4>Are you sure you want to delete this movie?</h4>
<hr />

<div>

    <p><b>Title:</b> @Model.Title</p>
    <p><b>Genre:</b> @Model.Genre</p>
    <p><b>Release Date:</b> @Model.ReleaseDate.ToShortDateString()</p>
    <p><b>Price:</b> @Model.Price</p>
    <p><b>Rating:</b> @Model.Rating</p>

</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>