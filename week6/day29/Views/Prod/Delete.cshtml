@using WebApplication3.Controllers
@model Products

<h1 class="display-5"> Product Controller -Delete</h1>

@if(Model==null)
{
	<p>Requested Product Details are not available</p>
}
else
{
	<div>
		ProductId =@Model.Pid<br />
		ProductName=@Model.Pname<br />
		ProductPrice=@Model.Pprice<br />
		ProductCategory=@Model.Pcategory<br />

	</div>
}
<br />

<form asp-action="Delete" method="post">
	<input type="hidden" name="id" value="@Model.Pid" />

	<div class="alert alert-danger">
		Are you sure you want to delete this product?
	</div><br />

@*	<p>Do you want to delete this product details?</p>*@
	<button type="submit" class="btn btn-success">Delete</button>
	<a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>